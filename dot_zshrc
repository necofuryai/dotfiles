if [ -f '/Users/masyusakai/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/masyusakai/google-cloud-sdk/completion.zsh.inc'; fi
export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"

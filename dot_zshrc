# ============================================
# .zshrc
# ============================================

for f in ~/.config/shell/{common,zsh}.sh; do
    [ -r "$f" ] && . "$f"
done

if [[ "$(uname)" == "Darwin" ]]; then
    alias brewup='brew update && brew upgrade --greedy && brew autoremove && brew cleanup && brew doctor; if ! git -C ~/.local/share/chezmoi diff --quiet; then git -C ~/.local/share/chezmoi add -A && git -C ~/.local/share/chezmoi commit -m "update dotfiles" && git -C ~/.local/share/chezmoi push; fi'

    # brew() and _update_brewfile defined in zsh.sh
    export EDITOR=nvim

    # Claude
    claude-or() {
        local token
        token="$(_secret_value "shell-env:ANTHROPIC_AUTH_TOKEN_OPENROUTER" "op://Personal/OPENROUTER_API_KEY/credential")"
        if [[ -z "$token" ]]; then
            echo "missing secret: shell-env:ANTHROPIC_AUTH_TOKEN_OPENROUTER" >&2
            return 1
        fi
        ANTHROPIC_BASE_URL="https://openrouter.ai/api" ANTHROPIC_AUTH_TOKEN="$token" ANTHROPIC_API_KEY="" MAX_THINKING_TOKENS="0" command claude "$@"
    }

    claude-mm() {
        local token
        token="$(_secret_value "shell-env:ANTHROPIC_AUTH_TOKEN_MINIMAX" "op://Personal/MINIMAX_API_KEY/credential")"
        if [[ -z "$token" ]]; then
            echo "missing secret: shell-env:ANTHROPIC_AUTH_TOKEN_MINIMAX" >&2
            return 1
        fi
        ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic" ANTHROPIC_AUTH_TOKEN="$token" ANTHROPIC_MODEL="MiniMax-M2.1" command claude "$@"
    }
    alias claude-mem='bun "/Users/masyusakai/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'

    # Go
    export GOENV_ROOT="$HOME/.goenv"
    export GOPATH="$HOME/go"
    export PATH="$GOENV_ROOT/bin:$PATH"
    eval "$(goenv init -)"
    export PATH="$GOPATH/bin:$PATH"
fi

pdfview() {
  local pdf="$1"
  local dpi="${2:-200}"
  local pages=$(mutool info "$pdf" 2>/dev/null | grep "^Pages:" | awk '{print $2}')

  if [[ "$pages" -gt 50 ]]; then
    echo "This PDF has $pages pages. Continue? [y/N]"
    read -r answer
    [[ "$answer" != [yY] ]] && return 0
  fi

  local tmp_dir="/tmp/pdfview_$$"
  mkdir -p "$tmp_dir"
  mutool draw -o "$tmp_dir/page%d.png" -r "$dpi" "$pdf"
  timg -W "$tmp_dir"/page*.png
  rm -rf "$tmp_dir"
}

# bun completions
[ -s "/Users/masyusakai/.bun/_bun" ] && source "/Users/masyusakai/.bun/_bun"

# Context7 API Key
